# Runtime data
/output/*
!/output/.gitkeep
/source/*
!/source/.gitkeep

# Python cache and build artifacts
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Tooling and local state
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Great Expectations generated local artifacts
/gx/
/great_expectations/uncommitted/

# Local environment files
.env
.env.*
